# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection string (Transaction pooler) — only for running migrations from scripts
DATABASE_URL=
# Personal Access Token for the Supabase Management API (auth config, project
# settings, etc.). Generate at https://supabase.com/dashboard/account/tokens.
# NEVER paste this into chat, commits, or logs. Used only via shell
# substitution (`$SUPABASE_MANAGEMENT_TOKEN`), never echo'd.
SUPABASE_MANAGEMENT_TOKEN=

# Mercado Pago
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Resend
RESEND_API_KEY=

# Sentry — DSN goes in NEXT_PUBLIC_ for browser access; SENTRY_DSN duplicates for server.
# ORG/PROJECT and AUTH_TOKEN are only needed at build time to upload source maps.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Scraping
SCRAPER_USER_AGENT=
SCRAPER_PROXY_URL=

# App
NEXT_PUBLIC_APP_URL=
INTERNAL_API_KEY=
